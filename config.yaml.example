# 造梦.skill 配置（本地无模型模式）

# 本地引擎配置
llm:
  provider: "local-rule-engine"
  model: "local-rule-engine"
  temperature: 0.0
  max_tokens: 0

engine:
  name: "local-rule-engine"
  pseudo_cost_per_1k_tokens_usd: 0.001

# 成本控制
cost_control:
  daily_budget_usd: 10.0  # 每日预算上限
  enable_cost_warning: true
  warning_threshold: 0.8  # 预算使用 80% 时警告

# 文本处理配置
text_processing:
  chunk_size_tokens: 8000
  chunk_overlap_tokens: 200
  min_sentence_length: 10

# 人物蒸馏配置
distillation:
  max_characters: 10  # 默认提取的主要人物数量
  min_appearances: 3  # 人物至少出现次数
  traits_max_count: 10  # 性格特质最多数量
  values_dimensions:  # 价值观维度
    - "勇气"
    - "智慧"
    - "善良"
    - "忠诚"
    - "野心"
    - "正义"
    - "自由"
    - "责任"

# 关系提取配置
relationships:
  dimensions:  # 关系维度
    - "trust"  # 信任度 0-10
    - "affection"  # 亲密度 0-10
    - "power_gap"  # 权力差距 -5到5
    - "conflict_point"  # 冲突点
    - "typical_interaction"  # 典型互动模式

# 聊天引擎配置
chat_engine:
  max_history_turns: 10
  token_limit_per_turn: 500
  enable_cost_display: true

# 文件路径配置
paths:
  characters: "data/characters"
  relations: "data/relations"
  sessions: "data/sessions"
  corrections: "data/corrections"
  logs: "logs"

# 系统配置
system:
  log_level: "INFO"
  enable_auto_save: true
  backup_interval_hours: 24
